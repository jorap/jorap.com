{
  "name": "jorap-com",
  "description": "JoRap Notes — personal blog and portfolio (Hugo + Tailwind).",
  "version": "2.2.0",
  "license": "MIT",
  "author": "JoRap",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/noteFileDates.js --watch\" \"hugo server --buildDrafts --buildFuture\"",
    "build": "pnpm run deploy",
    "deploy": "node scripts/deployBuild.mjs",
    "serve": "node scripts/servePublic.mjs",
    "preview:prod": "node scripts/previewProd.mjs",
    "preview": "node scripts/themeGenerator.js && node scripts/noteFileDates.js && hugo server --buildDrafts --buildFuture --disableFastRender --navigateToChanged --templateMetrics --templateMetricsHints --watch --forceSyncStatic -e production --minify --baseURL=http://localhost:1313/ --appendPort=false",
    "watch": "concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/noteFileDates.js --watch\" \"hugo server --buildDrafts --buildFuture --disableFastRender --navigateToChanged --templateMetrics --templateMetricsHints --watch --forceSyncStatic -e production --minify --baseURL=http://localhost:1313/ --appendPort=false\"",
    "update-modules": "node ./scripts/clearModules.js && hugo mod clean --all && hugo mod get -u ./... && hugo mod tidy",
    "format": "prettier -w .",
    "wire:notes": "python3 scripts/wire-notes-obsidian.py",
    "export:anki": "python3 scripts/export-anki-deck.py",
    "import:obsidian": "python3 scripts/import-from-obsidian.py",
    "lint:notes": "node scripts/themeGenerator.js && node scripts/noteFileDates.js && hugo --gc 2>&1 | rg 'broken wikilink|unlinked mention' || true",
    "lint:cards": "python3 scripts/lint-flashcard-frontmatter.py",
    "lint:voice": "python3 scripts/notes-voice-sanitize.py --check",
    "lint:utility-links": "python3 scripts/lint-utility-wikilinks.py",
    "postinstall": "node scripts/fix-tailwind-bin.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "0.0.15",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  }
}
