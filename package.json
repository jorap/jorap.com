{
  "name": "jorap-com",
  "description": "JoRap Notes — personal blog and portfolio (Hugo + Tailwind).",
  "version": "2.2.0",
  "license": "MIT",
  "author": "JoRap",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "dev": "concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/noteFileDates.js --watch\" \"hugo server --buildDrafts --buildFuture -e development --baseURL=http://localhost:1313/\"",
    "build": "node scripts/deployBuild.mjs",
    "deploy": "node scripts/deployBuild.mjs",
    "serve": "node scripts/servePublic.mjs",
    "preview:prod": "node scripts/previewProd.mjs",
    "hugo:prod-server": "hugo server --buildDrafts --buildFuture --disableFastRender --navigateToChanged --templateMetrics --templateMetricsHints --watch --forceSyncStatic -e production --minify --baseURL=http://localhost:1313/ --appendPort=false",
    "preview": "node scripts/themeGenerator.js && node scripts/noteFileDates.js && pnpm run hugo:prod-server",
    "watch": "concurrently \"node scripts/themeGenerator.js --watch\" \"node scripts/noteFileDates.js --watch\" \"pnpm run hugo:prod-server\"",
    "update-modules": "node ./scripts/clearModules.js && hugo mod clean --all && hugo mod get -u ./... && hugo mod tidy",
    "format": "prettier -w .",
    "export:anki": "python3 scripts/export-anki-deck.py",
    "export:okf": "python3 scripts/export-okf-bundle.py",
    "export:okf-blog": "python3 scripts/export-okf-blog-bundle.py",
    "import:obsidian": "python3 scripts/import-from-obsidian.py",
    "lint:notes": "node scripts/themeGenerator.js && node scripts/noteFileDates.js && hugo --gc 2>&1 | rg 'broken wikilink|unlinked mention' || true",
    "lint:frontmatter": "python3 scripts/lint-notes-frontmatter.py",
    "lint:cards": "python3 scripts/lint-flashcard-frontmatter.py",
    "audit:cards": "python3 scripts/audit-flashcard-north-star.py",
    "lint:garden": "python3 scripts/lint-notes-frontmatter.py && python3 scripts/normalize-notes-format.py --verify && python3 scripts/lint-flashcard-frontmatter.py && python3 scripts/audit-flashcard-north-star.py && python3 scripts/lint-utility-wikilinks.py && python3 scripts/garden-voice-lint.py --check && python3 scripts/slop-lint.py --check --notes-only",
    "lint:voice": "python3 scripts/notes-voice-sanitize.py --check && python3 scripts/notes-voice-lint.py --check",
    "lint:blog": "python3 scripts/normalize-blog-frontmatter.py --verify && python3 scripts/slop-lint.py --check --blog-only",
    "lint:slop": "python3 scripts/slop-lint.py --check",
    "slop:scan": "python3 scripts/slop-lint.py --summary",
    "lint:garden-voice": "python3 scripts/garden-voice-lint.py --check",
    "garden-voice:scan": "python3 scripts/garden-voice-lint.py --summary",
    "voice:scan": "python3 scripts/notes-voice-lint.py --summary --review",
    "lint:utility-links": "python3 scripts/lint-utility-wikilinks.py",
    "test:search": "node scripts/test-search.mjs",
    "setup:hooks": "sh scripts/setup-git-hooks.sh",
    "postinstall": "node scripts/fix-tailwind-bin.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "0.0.15",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwind-bootstrap-grid": "^7.0.0",
    "tailwindcss": "^4.3.1"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  }
}
